# WAF Environment Configuration

# ModSecurity Configuration
MODSECURITY_MODE=DetectionOnly
# Options: DetectionOnly, On, Disabled

# OWASP CRS Configuration
OWASP_CRS_VERSION=4.2.0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_BURST=50
RATE_LIMIT_DELAY_MS=50

# Connection Settings
MAX_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65

# Logging
LOG_LEVEL=warn
MODSECURITY_LOG_DIR=/var/log/modsecurity

# Allowed IPs (whitelist)
ALLOWED_IPS=

# Blocked IPs (blacklist)
BLOCKED_IPS=

# TLS Settings
TLS_CERT_PATH=/etc/nginx/ssl/cert.pem
TLS_KEY_PATH=/etc/nginx/ssl/key.pem

# Backend Services
BACKEND_UPSTREAM=app:3000
