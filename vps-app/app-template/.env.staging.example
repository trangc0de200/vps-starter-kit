# Application Staging Template

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=staging
APP_PORT=3000
APP_DEBUG=true
APP_URL=https://staging.example.com
APP_VERSION=1.0.0

# ===========================================
# DATABASE
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb_staging
DB_USER=appuser
DB_PASSWORD=<generate>
DB_SSL_MODE=disable

# ===========================================
# REDIS
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<generate>
REDIS_DB=1

# ===========================================
# SECURITY
# ===========================================
SESSION_SECRET=<generate>
JWT_SECRET=<generate>
ENCRYPTION_KEY=<generate>

# ===========================================
# EMAIL
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=<generate>
SMTP_FROM=noreply-staging@example.com

# ===========================================
# MONITORING
# ===========================================
PROMETHEUS_ENABLED=true
SENTRY_DSN=https://<key>@sentry.io/<project>
SENTRY_ENVIRONMENT=staging

# ===========================================
# BACKUP
# ===========================================
BACKUP_ENABLED=false
