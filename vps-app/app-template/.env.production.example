# Application Production Template

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=production
APP_PORT=3000
APP_DEBUG=false
APP_URL=https://example.com
APP_VERSION=1.0.0

# ===========================================
# DATABASE
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=<generate>
DB_SSL_MODE=require

# ===========================================
# REDIS
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<generate>
REDIS_DB=0

# ===========================================
# SECURITY
# ===========================================
SESSION_SECRET=<generate>
JWT_SECRET=<generate>
ENCRYPTION_KEY=<generate>

# ===========================================
# EMAIL
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=<generate>
SMTP_FROM=noreply@example.com

# ===========================================
# MONITORING
# ===========================================
PROMETHEUS_ENABLED=true
SENTRY_DSN=https://<key>@sentry.io/<project>
SENTRY_ENVIRONMENT=production

# ===========================================
# BACKUP
# ===========================================
BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_KEEP=7
