#!/usr/bin/env bash
# Backup Script
# Backup application data

set -euo pipefail

# Configuration
BACKUP_DIR="${BACKUP_DIR:-${APP_DIR}/backups}"
KEEP="${BACKUP_KEEP:-7}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
COMPRESS="${BACKUP_COMPRESS:-true}"
DESTINATION="${BACKUP_DESTINATION:-}"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}Starting backup...${NC}"

# Create backup directory
mkdir -p "$BACKUP_DIR"

# Backup name
BACKUP_NAME="app_backup_${TIMESTAMP}"
BACKUP_PATH="${BACKUP_DIR}/${BACKUP_NAME}"

# Create temp directory
mkdir -p "/tmp/${BACKUP_NAME}"

# Backup data directory
if [[ -d "${APP_DIR}/data" ]]; then
    echo "Backing up data..."
    cp -r "${APP_DIR}/data" "/tmp/${BACKUP_NAME}/"
fi

# Backup database
if [[ -f "${APP_DIR}/docker-compose.yml" ]]; then
    cd "$APP_DIR"
    
    # PostgreSQL
    if docker-compose exec -T db pg_dump -U postgres appdb > "/tmp/${BACKUP_NAME}/database.sql" 2>/dev/null; then
        echo "Database backed up"
    fi
fi

# Backup config (exclude secrets)
if [[ -d "${APP_DIR}/config" ]]; then
    cp -r "${APP_DIR}/config" "/tmp/${BACKUP_NAME}/"
fi

# Create archive
cd /tmp
if [[ "$COMPRESS" == "true" ]]; then
    tar -czf "${BACKUP_PATH}.tar.gz" "${BACKUP_NAME}"
    rm -rf "/tmp/${BACKUP_NAME}"
    FINAL_PATH="${BACKUP_PATH}.tar.gz"
else
    mv "/tmp/${BACKUP_NAME}" "${BACKUP_PATH}"
    FINAL_PATH="$BACKUP_PATH"
fi

# Upload to remote if configured
if [[ -n "$DESTINATION" ]]; then
    echo "Uploading to $DESTINATION..."
    
    if [[ "$DESTINATION" =~ ^s3:// ]]; then
        aws s3 cp "$FINAL_PATH" "$DESTINATION/" 2>/dev/null || \
        s3cmd put "$FINAL_PATH" "$DESTINATION/" 2>/dev/null || \
        echo -e "${RED}AWS CLI or s3cmd not found${NC}"
    elif [[ "$DESTINATION" =~ ^b2:// ]]; then
        b2 upload-file "$(echo "$DESTINATION" | cut -d/ -f3)" "$FINAL_PATH" "$(echo "$DESTINATION" | cut -d/ -f4-)" 2>/dev/null || \
        echo -e "${RED}B2 CLI not found${NC}"
    fi
fi

# Cleanup old backups
if [[ -d "$BACKUP_DIR" ]]; then
    echo "Cleaning up old backups (keeping $KEEP)..."
    ls -t "$BACKUP_DIR"/app_backup_*.tar.gz 2>/dev/null | tail -n +$((KEEP + 1)) | xargs -r rm -f
fi

# Summary
echo ""
echo -e "${GREEN}Backup complete!${NC}"
echo "Location: $FINAL_PATH"
echo "Size: $(du -h "$FINAL_PATH" | cut -f1)"
