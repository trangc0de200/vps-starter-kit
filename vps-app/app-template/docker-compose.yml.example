services:
  app:
    image: your-image-or-build
    container_name: my-app
    restart: unless-stopped
    env_file:
      - .env.production
    expose:
      - "3000"
    networks:
      - proxy_network
      - db_network

networks:
  proxy_network:
    external: true
  db_network:
    external: true
