# MySQL Configuration

# Container
MYSQL_VERSION=8.0
MYSQL_CONTAINER_NAME=mysql

# Database
MYSQL_DATABASE=appdb
MYSQL_USER=mysql
MYSQL_PASSWORD=change_me_strong_password

# Root
MYSQL_ROOT_PASSWORD=change_me_root_password

# Network
TZ=Asia/Ho_Chi_Minh

# Performance
MYSQL_MAX_CONNECTIONS=200
MYSQL_INNODB_BUFFER_POOL_SIZE=256M
MYSQL_INNODB_LOG_FILE_SIZE=64M
MYSQL_INNODB_FLUSH_LOG_AT_TRX_COMMIT=2
MYSQL_INNODB_FLUSH_METHOD=O_DIRECT
MYSQL_INNODB_IO_CAPACITY=400
MYSQL_INNODB_IO_CAPACITY_MAX=2000
MYSQL_TABLE_OPEN_CACHE=4000
MYSQL_TABLE_DEFINITION_CACHE=2000

# Query Cache (removed in MySQL 8.0)
# Not available in MySQL 8.0+

# Logging
MYSQL_LOG_BIN=mysql-bin
MYSQL_BINLOG_FORMAT=ROW
MYSQL_EXPIRE_LOGS_DAYS=7
MYSQL_SLOW_QUERY_LOG=1
MYSQL_LONG_QUERY_TIME=2
MYSQL_LOG_OUTPUT=FILE

# Character Set
MYSQL_CHARACTER_SET_SERVER=utf8mb4
MYSQL_COLLATION_SERVER=utf8mb4_unicode_ci

# Security
MYSQL_REQUIRE_SECURE_TRANSPORT=ON
MYSQL_AUTHENTICATION_POLICY=mysql_native_password

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 3 * * *"
BACKUP_RETENTION_DAYS=30

# Monitoring
MYSQL_EXPORTER_ENABLED=true
MYSQL_EXPORTER_PORT=9104
