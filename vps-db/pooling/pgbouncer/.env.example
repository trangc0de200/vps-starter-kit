# PgBouncer Environment Configuration

# Database Connection
DB_HOST=postgres
DB_PORT=5432
DB_NAME=appdb
DB_USER=postgres
DB_PASSWORD=changeme

# PgBouncer Admin
PGBOUNCER_ADMIN_USER=pgbouncer
PGBOUNCER_ADMIN_PASSWORD=admin_secret
PGBOUNCER_STATS_USER=stats
PGBOUNCER_STATS_PASSWORD=stats_secret

# Pool Configuration
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_MIN_POOL_SIZE=5
PGBOUNCER_RESERVE_POOL_SIZE=5
PGBOUNCER_RESERVE_POOL_TIMEOUT=5
PGBOUNCER_MAX_DB_CONNECTIONS=100
PGBOUNCER_IDLE_TRANSACTION_TIMEOUT=60

# Server Lifetime
PGBOUNCER_SERVER_LIFETIME=3600
PGBOUNCER_SERVER_IDLE_TIMEOUT=600

# Authentication
PGBOUNCER_AUTH_TYPE=md5
PGBOUNCER_AUTH_QUERY=SELECT usename, passwd FROM pg_shadow WHERE usename=$1

# Logging
PGBOUNCER_LOG_CONNECTIONS=1
PGBOUNCER_LOG_DISCONNECTIONS=1
PGBOUNCER_LOG_ERRORS=1
PGBOUNCER_LOG_WARNINGS=1

# Query Timeout
PGBOUNCER_QUERY_TIMEOUT=300
PGBOUNCER_CLIENTLogin_TIMEOUT=60

# Restart behavior
PGBOUNCER_SERVER_RESET_QUERY=DISCARD ALL
PGBOUNCER_SERVER_CHECK_DELAY=30
PGBOUNCER_SERVER_LIFETIME_CHECK_INTERVAL=60
