# ProxySQL Environment Configuration

# MySQL/MariaDB Connection
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=changeme

# ProxySQL Admin
PROXYSQL_ADMIN_USER=admin
PROXYSQL_ADMIN_PASSWORD=admin
PROXYSQL_MONITOR_USER=monitor
PROXYSQL_MONITOR_PASSWORD=monitor_secret

# Pool Configuration
PROXYSQL_MAX_CONNECTIONS=2048
PROXYSQL_DEFAULT_POOL_SIZE=25
PROXYSQL_MIN_POOL_SIZE=5
PROXYSQL_MAX_POOL_SIZE=50

# Query Cache
PROXYSQL_QUERY_CACHE_SIZE=256MB
PROXYSQL_QUERY_CACHE_STATS_ENABLED=1
PROXYSQL_QUERY_CACHE_ENABLED=1

# Connection Pool Settings
PROXYSQL_CONNECT_TIMEOUT=3000
PROXYSQL_PING_TIMEOUT=1000
PROXYSQL_SERVER_CONNECT_TIMEOUT=10000
PROXYSQL_SERVER_RESP_TIMEOUT=3600000
PROXYSQL_FREE_POOL_SIZE=8

# Throttling
PROXYSQL_MAX_QUERY_TIME=30000
PROXYSQL_THROTTLE_THRESHOLD=100000

# MySQL Version
MYSQL_VERSION=8.0
