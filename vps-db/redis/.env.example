# Redis Configuration

# Container
REDIS_VERSION=7.2-alpine
REDIS_CONTAINER_NAME=redis

# Authentication
REDIS_PASSWORD=change_me_strong_password

# Network
TZ=Asia/Ho_Chi_Minh

# Performance
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_DATABASES=16
REDIS_TCP_BACKLOG=511
REDIS_TCP_KEEPALIVE=300

# Persistence - RDB
REDIS_SAVE="900 1 300 10 60 10000"
REDIS_RDB_COMPRESSION=yes
REDIS_RDB_DEL_SYNC_FILES=yes

# Persistence - AOF
REDIS_APPENDONLY=yes
REDIS_APPENDFSYNC=everysec
REDIS_AUTO_AOF_REWRITE_PERCENTAGE=100
REDIS_AUTO_AOF_REWRITE_MIN_SIZE=64mb

# Replication
REDIS_REPLICA_READ_ONLY=yes
REDIS_REPL_SERVE_STALE_DATA=yes
REDIS_REPL_DISKLESS_SYNC=no

# Logging
REDIS_LOGLEVEL=notice

# Security
REDIS_PROTECTED_MODE=yes
REDIS_BIND=0.0.0.0

# Latency
REDIS_LATENCY_MONITOR_THRESHOLD=100

# Slow Log
REDIS_SLOWLOG_LOG_SLOWER_THAN=10000
REDIS_SLOWLOG_MAX_LEN=128

# Client Output Buffer
REDIS_CLIENT_OUTPUT_BUFFER_LIMIT_NORMAL=0 0 0
REDIS_CLIENT_OUTPUT_BUFFER_LIMIT_REPLICA=256mb 64mb 60
REDIS_CLIENT_OUTPUT_BUFFER_LIMIT_PUBSUB=32mb 8mb 60

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 4 * * *"
BACKUP_RETENTION_DAYS=30

# Monitoring
REDIS_EXPORTER_ENABLED=true
REDIS_EXPORTER_PORT=9121
