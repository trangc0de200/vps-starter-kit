# ELK Stack Environment Configuration

# Elasticsearch
ELASTICSEARCH_VERSION=8.13.4
ELASTICSEARCH_HEAP_SIZE=512m
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_PORT=9200

# Kibana
KIBANA_HOST=0.0.0.0
KIBANA_PORT=5601
KIBANA_SECURE=false

# Fluentd
FLUENTD_VERSION=v1.16-1
FLUENTD_BUFFER_TYPE=file
FLUENTD_BUFFER_PATH=/var/log/fluentd/buffer
FLUENTD_BUFFER_CHUNK_LIMIT=8KB
FLUENTD_BUFFER_QUEUE_LIMIT=256

# Elasticsearch Output
ES_HOST=elasticsearch
ES_PORT=9200
ES_INDEX_PREFIX=fluentd

# Log Retention
LOG_RETENTION_DAYS=30

# Alertmanager
ALERTMANAGER_PORT=9093
ALERTMANAGER_SMTP_HOST=smtp.gmail.com
ALERTMANAGER_SMTP_PORT=587
ALERTMANAGER_SMTP_FROM=alerts@yourdomain.com
ALERTMANAGER_SMTP_TO=admin@yourdomain.com

# Slack Alerting
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#alerts
SLACK_USERNAME=Alertmanager

# PagerDuty (optional)
PAGERDUTY_ROUTING_KEY=

# Prometheus metrics endpoint for Fluentd
FLUENTD_METRICS_PORT=24231
