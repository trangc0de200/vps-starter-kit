# Nginx Proxy Manager Configuration

# ===========================================
# Nginx Proxy Manager
# ===========================================
NPM_VERSION=2.11.3

# ===========================================
# Network
# ===========================================
NETWORK_NAME=npm_network
NETWORK_SUBNET=172.20.0.0/16

# ===========================================
# Ports
# ===========================================
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81

# ===========================================
# Database
# ===========================================
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=npm
MYSQL_USER=npm
MYSQL_PASSWORD=change_me_npm_password

# ===========================================
# MariaDB
# ===========================================
MARIADB_VERSION=latest
MYSQL_ROOT_PASSWORD=change_me_root_password

# ===========================================
# Timezone
# ===========================================
TZ=Asia/Ho_Chi_Minh
