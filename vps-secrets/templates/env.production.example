# Production Environment Template

# ===========================================
# APPLICATION
# ===========================================
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com
APP_SECRET_KEY=<generate-64>

# JWT Configuration
JWT_SECRET=<generate-64>
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# Session
SESSION_LIFETIME=7200
SESSION_DRIVER=redis
SESSION_SECRET=<generate-32>

# ===========================================
# DATABASE
# ===========================================
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=<generate>
POSTGRES_SSL_MODE=require

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=<generate>
MYSQL_SSL_CA=/secrets/mysql-ca.pem

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<generate>
REDIS_DB=0

# ===========================================
# SECURITY
# ===========================================
# Encryption
ENCRYPTION_KEY=<generate-32>
ENCRYPTION_CIPHER=AES-256-CBC

# CSRF
CSRF_TOKEN_SECRET=<generate-32>

# OAuth
OAUTH_CLIENT_ID=<client-id>
OAUTH_CLIENT_SECRET=<generate>
OAUTH_REDIRECT_URI=https://example.com/auth/callback

# ===========================================
# EXTERNAL SERVICES
# ===========================================
# AWS
AWS_ACCESS_KEY_ID=<key-id>
AWS_SECRET_ACCESS_KEY=<secret>
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=my-bucket

# SendGrid
SENDGRID_API_KEY=<api-key>
SENDGRID_FROM_EMAIL=noreply@example.com

# Stripe
STRIPE_PUBLIC_KEY=<pk_test_...>
STRIPE_SECRET_KEY=<sk_test_...>
STRIPE_WEBHOOK_SECRET=<whsec_...>

# ===========================================
# MONITORING
# ===========================================
# Prometheus
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_TOKEN=<token>

# Grafana
GRAFANA_URL=http://grafana:3002
GRAFANA_TOKEN=<token>

# Sentry
SENTRY_DSN=https://<key>@sentry.io/<project>
SENTRY_ENVIRONMENT=production

# ===========================================
# NOTIFICATIONS
# ===========================================
# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<token>

# Telegram
TELEGRAM_BOT_TOKEN=<bot-token>
TELEGRAM_CHAT_ID=<chat-id>

# ===========================================
# BACKUP
# ===========================================
# AWS S3
BACKUP_S3_BUCKET=my-backups
BACKUP_AWS_ACCESS_KEY_ID=<key-id>
BACKUP_AWS_SECRET_ACCESS_KEY=<secret>

# B2
B2_ACCOUNT_ID=<account-id>
B2_APPLICATION_KEY=<key>

# ===========================================
# SSL/TLS
# ===========================================
SSL_CERT_PATH=/secrets/cert.pem
SSL_KEY_PATH=/secrets/key.pem
SSL_CA_PATH=/secrets/ca.pem
