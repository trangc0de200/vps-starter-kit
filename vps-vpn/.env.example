# WireGuard Environment Configuration

# Server Settings
WG_HOST=your-vps-ip.example.com
WG_PORT=51820
WG_MTU=1420

# Network Configuration
WG_NETWORK=10.0.0
WG_SUBNET=24
WG_ADDRESS=${WG_NETWORK}.1/24

# DNS
WG_DNS=1.1.1.1,1.0.0.1  # Cloudflare
# WG_DNS=8.8.8.8,8.8.4.4  # Google
# WG_DNS=9.9.9.9,149.112.112.112  # Quad9

# Allowed IPs (0.0.0.0/0 for full tunnel)
WG_ALLOWED=0.0.0.0/0,::/0

# Web UI Settings (wg-easy)
WEBUI_PORT=51821
WEBUI_PASSWORD=change_me_strong_password

# Peer Management
WG_PERSISTENT_KEEPALIVE=25

# Logging
LOG_LEVEL=info

# Timezone
TZ=Asia/Ho_Chi_Minh
